{
  "name": "dipghosh/laravel-env-checker",
  "description": "Laravel environment health checker",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Dipghosh\\LaravelEnvChecker\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Dip Ghosh"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../laravel-env-checker"
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Dipghosh\\LaravelEnvChecker\\EnvCheckerServiceProvider"
      ]
    }
  }
}
